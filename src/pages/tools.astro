---
import Layout from "@/layouts/Layout.astro";

const devTools = [
    { title: "Shell", value: "zsh", desc: "Switched from bash for better plugin support.", href: null },
    { title: "Text editor", value: "Neovim", desc: "My swiss army knife. Using it since my first year of college.", href: "https://neovim.io/" },
    { title: "Terminal", value: "foot", desc: "A nice terminal written in C.", href: "https://codeberg.org/dnkl/foot" },
    { title: "Database", value: "DataGrip", desc: "Free educational license through my MSc program.", href: "https://www.jetbrains.com/datagrip/" },
    { title: "Browser", value: "Helium", desc: "Simplicity, no privacy concerns. Avoiding bloat.", href: "https://helium.computer/" },
    { title: "Code assistant", value: "OpenCode", desc: 'Running multiple LLMs, but now actively using nvidia/Qwen3.6-27B-NVFP4. I prefer to "operate" it and understand the solution before using it.', href: "https://opencode.ai/" },
    { title: "Dotfiles", value: "pebeto/dotfiles", desc: "My whole working environment in one repo: Sway, Neovim, zsh and the rest.", href: "https://github.com/pebeto/dotfiles" },
];

const personalTools = [
    { title: "Journaling", value: "Moleskine notebook", desc: "Paper keeps my mind focused and avoids digital distractions.", href: "https://www.moleskine.com/en-us/" },
    { title: "Agenda", value: "Org Mode", desc: "Used in Neovim via nvim-orgmode. Never miss a birthday message.", href: "https://orgmode.org/" },
    { title: "Pocket notes", value: "Traveler's notebook", desc: "Passport size, doubles as a wallet. Always with me.", href: "https://shop.travelerscompanyusa.com/products/travelers-notebook-passport-size-brown" },
    { title: "Syncing", value: "Syncthing", desc: "Self-hosted file sync. No third-party services.", href: "https://syncthing.net/" },
];
---

<Layout
    title="Tools"
    description="The software and hardware Jose Esparza uses daily: Arch Linux, Neovim, Sway, zsh and more."
    canonical="/tools"
>
    <main class="max-w-6xl mx-auto px-6 sm:px-12 py-16 space-y-16">
        <section class="max-w-3xl">
            <h2
                class="text-2xl font-semibold text-[var(--color-heading)] mb-5"
            >
                Why this page?
            </h2>
            <p class="text-[var(--color-text)] leading-relaxed">
                Good tools shape good work. In college I kept handing tool
                recommendations to classmates. This page is the grown-up version
                of that habit.
            </p>
        </section>

        <section class="max-w-3xl">
            <h2
                class="text-2xl font-semibold text-[var(--color-heading)] mb-5"
            >
                OS
            </h2>
            <div class="text-[var(--color-text)] leading-relaxed">
                <p>
                    <a
                        href="https://archlinux.org/"
                        target="_blank"
                        class="font-semibold text-[var(--color-heading)]"
                    >
                        Arch Linux
                    </a>{" "}
                    on Thinkpad T470 and desktop. Window manager is{" "}
                    <a href="https://swaywm.org/" target="_blank">Sway</a>. I'm
                    in the fields of Wayland.
                </p>
            </div>
        </section>

        <section class="max-w-3xl space-y-6">
            <h2 class="text-2xl font-semibold text-[var(--color-heading)]">
                Development tools
            </h2>
            <div class="space-y-5">
                {
                    devTools.map((tool) => (
                        <div class="border-t border-[var(--color-border-light)] pt-5">
                            <div class="flex items-baseline gap-2 flex-wrap">
                                <span class="text-sm text-[var(--color-text-faint)] uppercase tracking-wider">
                                    {tool.title}
                                </span>
                                {tool.href ? (
                                    <a
                                        href={tool.href}
                                        target="_blank"
                                        class="font-semibold text-[var(--color-heading)]"
                                    >
                                        {tool.value}
                                    </a>
                                ) : (
                                    <span class="font-semibold text-[var(--color-heading)]">
                                        {tool.value}
                                    </span>
                                )}
                            </div>
                            <p class="text-sm text-[var(--color-text-muted)] mt-2">
                                {tool.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </section>

        <section class="max-w-3xl space-y-6">
            <h2 class="text-2xl font-semibold text-[var(--color-heading)]">
                Personal tools
            </h2>
            <div class="space-y-5">
                {
                    personalTools.map((tool) => (
                        <div class="border-t border-[var(--color-border-light)] pt-5">
                            <div class="flex items-baseline gap-2 flex-wrap">
                                <span class="text-sm text-[var(--color-text-faint)] uppercase tracking-wider">
                                    {tool.title}
                                </span>
                                <a
                                    href={tool.href}
                                    target="_blank"
                                    class="font-semibold text-[var(--color-heading)]"
                                >
                                    {tool.value}
                                </a>
                            </div>
                            <p class="text-sm text-[var(--color-text-muted)] mt-2">
                                {tool.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </section>
    </main>
</Layout>
