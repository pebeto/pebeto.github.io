---
interface Props {
    tags: string[];
    activeTag: string | null;
}

const { tags, activeTag } = Astro.props;

const baseInactive =
    "border border-[var(--color-border)] text-[var(--color-text-muted)] hover:border-[var(--color-text-faint)]";
const baseActive = "bg-[var(--color-tag-active-bg)]";
---

<div class="flex flex-wrap gap-2 mb-10">
    <a
        href="/blog"
        style={activeTag === null ? "color: var(--color-tag-active-text)" : undefined}
        class={`px-3 py-1 text-xs rounded-full transition-colors ${
            activeTag === null ? baseActive : baseInactive
        }`}
    >
        all
    </a>
    {
        tags.map((tag) => (
            <a
                href={`/blog/tag/${tag}`}
                style={
                    activeTag === tag
                        ? "color: var(--color-tag-active-text)"
                        : undefined
                }
                class={`px-3 py-1 text-xs rounded-full transition-colors ${
                    activeTag === tag ? baseActive : baseInactive
                }`}
            >
                {tag}
            </a>
        ))
    }
</div>
